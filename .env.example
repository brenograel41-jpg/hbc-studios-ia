# GHS STUDIOS IA - Environment Configuration

# ============================================================
# FREE AI MODELS
# ============================================================

# Google Gemini (Free tier available)
GOOGLE_API_KEY=your_google_api_key_here

# Hugging Face (Free models available)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# ============================================================
# PAID AI MODELS
# ============================================================

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MODEL_FALLBACK=gpt-3.5-turbo

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# Cohere
COHERE_API_KEY=your_cohere_api_key_here
COHERE_MODEL=command

# ============================================================
# CHAT SETTINGS
# ============================================================

# Default model to use (must be configured above)
DEFAULT_MODEL=gpt-3.5-turbo

# Chat configuration
MAX_HISTORY=50
TEMPERATURE=0.7
MAX_TOKENS=2000
TOP_P=1.0

# System prompt
SYSTEM_PROMPT=Você é um assistente inteligente e prestativo criado por GHS Studios. Responda com precisão, clareza e de forma útil.

# ============================================================
# INTEGRATIONS
# ============================================================

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_COMMAND_PREFIX=!

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Slack Bot (optional)
SLACK_BOT_TOKEN=your_slack_bot_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# ============================================================
# DATABASE
# ============================================================

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ghs_studios_ia

# MongoDB (alternative)
MONGODB_URL=mongodb://localhost:27017/ghs_studios_ia

# ============================================================
# SERVER
# ============================================================

# Flask
FLASK_ENV=development
FLASK_DEBUG=False
SECRET_KEY=your_secret_key_here

# Server
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO

# ============================================================
# SECURITY
# ============================================================

# API Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# ============================================================
# MONITORING & LOGGING
# ============================================================

# Sentry (error tracking)
SENTRY_DSN=your_sentry_dsn_here

# Custom logging
LOG_FILE=logs/ghs_studios_ia.log
ENABLE_ANALYTICS=True

# ============================================================
# FEATURES
# ============================================================

# Enable/Disable features
ENABLE_WEB_UI=True
ENABLE_DISCORD=True
ENABLE_TELEGRAM=True
ENABLE_SLACK=False
ENABLE_VOICE=False

# Cache settings
CACHE_ENABLED=True
CACHE_TTL=3600

# ============================================================
# DEVELOPMENT
# ============================================================

# Debug mode
DEBUG=False
DEVELOPMENT_MODE=False

# Test settings
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/ghs_studios_ia_test